{
  "name": "aslx-sfn",
  "version": "0.4.3",
  "type": "module",
  "description": "TypeScript (SWC) -> JSONata compiler for embedding JSONata in Step Functions authoring workflows.",
  "keywords": [
    "aws",
    "step-functions",
    "asl",
    "jsonata",
    "dsl",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aslx": "./dist/cli/aslx.js",
    "aslx-compile-jsonata": "./dist/cli/compile-jsonata.js",
    "aslx-build-machine": "./dist/cli/build-machine.js",
    "aslx-validate-machine": "./dist/cli/validate-machine.js",
    "aslx-build-yml": "./dist/cli/build-yml.js"
  },
  "scripts": {
    "format": "prettier -w .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test",
    "compile": "tsx compiler/compile-jsonata.ts machines/index.ts",
    "build:slots": "tsx compiler/compile-jsonata.ts machines/index.ts --out build/slots.json",
    "build:machine": "npm run build:slots && tsx compiler/build-machine.ts machines/index.ts --slots build/slots.json --out-dir build/machines",
    "build:yml": "npm run build:machine && tsx compiler/build-yml.ts --in-dir build/machines --out-dir build/machines",
    "watch": "tsx compiler/compile-jsonata.ts machines/index.ts --out build/slots.json --watch",
    "validate:machine": "tsx compiler/validate-machine.ts machines/index.ts",
    "test": "npm run test:golden && npm run test:validator:negative && npm run test:compiler:negative && npm run test:aws-sdk && npm run test:conditions && npm run test:catch && npm run test:task-controls && npm run test:parallel && npm run test:map",
    "test:golden": "tsx tests/golden.ts",
    "test:golden:update": "tsx tests/golden.ts --update",
    "test:validator:negative": "tsx tests/validator-negative.ts",
    "test:compiler:negative": "tsx tests/compiler-negative.ts",
    "test:aws-sdk": "tsx tests/aws-sdk-builder.ts",
    "test:conditions": "tsx tests/choice-conditions.ts",
    "test:catch": "tsx tests/catch-builder.ts",
    "test:task-controls": "tsx tests/task-controls.ts",
    "test:parallel": "tsx tests/parallel.ts",
    "test:map": "tsx tests/map.ts"
  },
  "dependencies": {
    "@swc/core": "^1.5.29",
    "tsx": "^4.19.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.13.0",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  }
}