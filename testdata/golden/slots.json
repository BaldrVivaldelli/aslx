{
  "example:Validate/param:validationExpr": "{%\n(\n  $bar := function(){ \"BAR\" };\n\n  $foo := function($x){ (\"DEFAULT_\" & $x) };\n\n  $u__default := function($x){ (\"DEFAULT_\" & $x) };\n\n  $u__foo_bar := function(){ \"FOO_BAR\" };\n\n  $EMPTY_OBJ := {};\n\n  $EMPTY_PARAMS := {};\n\n  $states := $states;\n\n  $coalesce := function($a,$b){ ($exists($a) ? $a : $b) };\n\n  $body := $coalesce($states.input.body, $EMPTY_OBJ);\n\n  $params := $coalesce($states.input.params, $EMPTY_PARAMS);\n\n  $pathParams := $coalesce($params.path, $EMPTY_OBJ);\n\n  $qs := $coalesce($params.querystring, $EMPTY_OBJ);\n\n  $schema := {\"alias\": {\"type\": \"string\", \"required\": true}, \"slug\": {\"type\": \"string\", \"required\": true}, \"overrides\": {\"type\": \"object\", \"required\": false}};\n\n  $schemaKeys := $keys($schema);\n\n  $payload := $merge([$qs, $pathParams, $body]);\n\n  $missing := $schemaKeys[( $def := $lookup($schema, $); $v := $lookup($payload, $); (($def.required = true) and ($exists($v) = false)) )];\n\n  $clean := $reduce($schemaKeys, function($acc,$k){ ( $v := $lookup($payload, $k); ($exists($v) ? $merge([$acc, {($k): $v}]) : $acc) ) }, $EMPTY_OBJ);\n\n  $noteA := $bar();\n\n  $noteB := $foo(\"X\");\n\n  $noteC := $u__foo_bar();\n\n  $noteD := $u__default(\"Y\");\n\n  $numericPlus := (1 + 2);\n\n  $stringyPlus := (\"A\" & \"B\");\n\n  {\"valid\": ($count($missing) = 0), \"input\": $clean, \"errors\": {\"missing\": $missing}, \"notes\": {\"noteA\": $noteA, \"noteB\": $noteB, \"noteC\": $noteC, \"noteD\": $noteD}, \"demoKey\": (\"ALIAS#\" & $uppercase(\"visa\")), \"numericPlus\": $numericPlus, \"stringyPlus\": $stringyPlus}\n)\n%}",
  "example:Choice/isValidationOk": "{%\n(\n  $states := $states;\n\n  $validation := $states.input.validation;\n\n  ($exists($validation) and ($validation.valid = true))\n)\n%}",
  "example:Choice/validationMode": "{%\n(\n  $states := $states;\n\n  $states.input.validation.mode\n)\n%}",
  "example:Choice/validationSource": "{%\n(\n  $states := $states;\n\n  $states.input.validation.source\n)\n%}",
  "example:Echo/output": "{%\n(\n  {\"body\": $states.input, \"statusCode\": 200}\n)\n%}",
  "package:task/getPackage/key": "{%\n(\n  $states.input.pk_sk\n)\n%}",
  "package:task/getPackage/output": "{%\n(\n  $merge([$states.input, {\"query_result\": $states.result}])\n)\n%}",
  "package:common/statesInput": "{%\n(\n  $states.input\n)\n%}",
  "package:task/computeMany/output": "{%\n(\n  $states.result.Payload\n)\n%}",
  "package:task/computeMany/resultSelectorPayload": "{%\n(\n  $states.result.Payload\n)\n%}",
  "package:task/computeMany/resultSelectorSource": "{%\n(\n  \"lambda_invoke\"\n)\n%}",
  "package:task/preparePackageModules/output": "{%\n(\n  {\"input\": $states.result.Payload.input, \"items_found\": $states.result.Payload.items_found, \"all_modules_valid\": $states.result.Payload.all_modules_valid}\n)\n%}",
  "package:choice/isPreparedModulesValid": "{%\n(\n  ($states.input.all_modules_valid = true)\n)\n%}",
  "merchant:task/getMerchantProfile/key": "{%\n(\n  {\"PK\": (\"MERCHANT#\" & $states.input.merchant_id), \"SK\": \"PROFILE\"}\n)\n%}",
  "merchant:task/getMerchantProfile/profile": "{%\n(\n  $states.input.merchant_profile\n)\n%}",
  "merchant:task/scoreMerchantOnboarding/approved": "{%\n(\n  $states.result.Payload.approved\n)\n%}",
  "merchant:task/scoreMerchantOnboarding/band": "{%\n(\n  $states.result.Payload.band\n)\n%}",
  "merchant:task/scoreMerchantOnboarding/reasons": "{%\n(\n  $states.result.Payload.reasons\n)\n%}",
  "merchant:task/scoreMerchantOnboarding/source": "{%\n(\n  \"risk_engine\"\n)\n%}",
  "merchant:choice/isMerchantAutoApproved": "{%\n(\n  ($states.input.decision.approved = true)\n)\n%}",
  "merchant:parallel/mergeContextOutput": "{%\n(\n  {\"merchant_context\": $states.input.parallel_results, \"merged\": true}\n)\n%}",
  "merchant:parallel/isEligible": "{%\n(\n  true\n)\n%}",
  "modules:common/validationMode": "{%\n(\n  $states := $states;\n\n  $states.input.validation.mode\n)\n%}",
  "modules:common/validationSource": "{%\n(\n  $states := $states;\n\n  $states.input.validation.source\n)\n%}",
  "modules:map/items": "{%\n(\n  $states := $states;\n\n  $modules := $states.input.modules;\n\n  ($exists($modules) ? $modules : [])\n)\n%}",
  "modules:map/itemIndex": "{%\n(\n  $states := $states;\n\n  $states.context.Map.Item.Index\n)\n%}",
  "modules:map/itemValue": "{%\n(\n  $states := $states;\n\n  $states.context.Map.Item.Value\n)\n%}",
  "modules:map/processor/index": "{%\n(\n  $states := $states;\n\n  $states.input.index\n)\n%}",
  "modules:map/processor/module": "{%\n(\n  $states := $states;\n\n  $states.input.module\n)\n%}",
  "modules:map/processor/mode": "{%\n(\n  $states := $states;\n\n  $states.input.mode\n)\n%}",
  "modules:map/processor/source": "{%\n(\n  $states := $states;\n\n  $states.input.source\n)\n%}",
  "modules:task/validateOneModule/valid": "{%\n(\n  $states := $states;\n\n  $states.result.Payload.valid\n)\n%}",
  "modules:task/validateOneModule/errors": "{%\n(\n  $states := $states;\n\n  $states.result.Payload.errors\n)\n%}",
  "modules:map/processor/returnValidation": "{%\n(\n  $states := $states;\n\n  $states.input.validation\n)\n%}",
  "modules:choice/allValid": "{%\n(\n  $states := $states;\n\n  $validations := $states.input.module_validations;\n\n  $invalid := $validations[($.valid != true)];\n\n  ($count($invalid) = 0)\n)\n%}",
  "modules:choice/invalid": "{%\n(\n  $states := $states;\n\n  $validations := $states.input.module_validations;\n\n  $validations[($.valid != true)]\n)\n%}",
  "modules:pass/persistValidatedModules/output": "{%\n(\n  $states := $states;\n\n  $validations := $states.input.module_validations;\n\n  {\"ok\": true, \"status\": \"modules_validated\", \"total\": $count($validations), \"validations\": $validations}\n)\n%}",
  "modules:pass/rejectInvalidModules/output": "{%\n(\n  $states := $states;\n\n  $validations := $states.input.module_validations;\n\n  $invalid := $validations[($.valid != true)];\n\n  {\"ok\": false, \"reason\": \"invalid_modules\", \"total\": $count($validations), \"invalid_count\": $count($invalid), \"invalid\": $invalid}\n)\n%}",
  "modules:pass/failModuleValidationRuntime/output": "{%\n(\n  $states := $states;\n\n  {\"ok\": false, \"reason\": \"module_validation_failed\", \"error\": $states.input.module_validation_error}\n)\n%}"
}
